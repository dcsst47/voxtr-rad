# ─── Twilio ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The +number Twilio has registered as your WhatsApp sender. Include the "whatsapp:" prefix or don't — either works.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Claude (agentic core) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Voice (STT — required for voice-note-in demos) ───
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Voice (TTS — needed for multi-language voice-note-out; recommended for Boom Health) ───
# If unset, non-English replies still send as TEXT — just not as a voice note.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ───
# BASE_URL is the public HTTPS URL Twilio can reach — Railway sets this to your app's public URL,
# for local dev use your ngrok URL. Without it, voice replies are skipped.
BASE_URL=https://voxtr-rad-production-xxxx.up.railway.app
PORT=3000
NODE_ENV=production
